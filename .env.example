# Port convention: 3141 = production (Docker, ~/code/recipes), 3142 = development (this repo).
# Copy to .env — docker compose picks it up automatically.
RECIPE_APP_PORT=3142

# Auth (see docs/running.md#authentication). Reads are public; CRUD needs a login.
# Set a strong random secret in production so sessions survive restarts:
#   openssl rand -base64 32
SESSION_SECRET=
# Secure cookie — keep true behind an HTTPS reverse proxy; set false only for local http.
COOKIE_SECURE=true
