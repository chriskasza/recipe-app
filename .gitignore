# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Tooling
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Runtime state: derived DB (rebuildable) + auth secrets. Never canonical —
# nothing here is committed except the .gitkeep that preserves the directory.
data/*
!data/.gitkeep

# Editor
.idea/
.vscode/
*.swp
.DS_Store

# Local scratch (transient outputs, log captures)
tmp/

# Developer scratch — populate via recipe-from-url skill; not committed
/recipes/
